{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Infinity Setup",
  "version": "1.0.0",
  "identifier": "com.infinityconnect.setup",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1430",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Установка Infinity Connect",
        "width": 560,
        "height": 400,
        "resizable": false,
        "maximizable": false,
        "center": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
