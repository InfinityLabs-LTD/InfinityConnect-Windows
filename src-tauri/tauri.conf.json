{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Infinity Connect",
  "version": "0.1.0",
  "identifier": "com.infinityconnect.windows",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Infinity Connect",
        "width": 420,
        "height": 720,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": ["binaries/*"],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}
