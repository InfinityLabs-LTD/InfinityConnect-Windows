{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Infinity Connect",
  "version": "1.0.0",
  "identifier": "com.infinityconnect.windows",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Infinity Connect",
        "width": 1120,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "createUpdaterArtifacts": true,
    "publisher": "Infinity Labs",
    "homepage": "https://github.com/InfinityLabs-LTD/InfinityConnect-Windows",
    "copyright": "© 2026 Infinity Labs",
    "shortDescription": "Infinity Connect — VPN-клиент",
    "longDescription": "Infinity Connect — VPN-клиент с гибридным ядром sing-box/Xray/Hysteria2, раздельным туннелированием по приложениям и гибкой маршрутизацией.",
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": ["binaries/*"],
    "windows": {
      "signCommand": {
        "cmd": "powershell",
        "args": [
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "../scripts/sign.ps1",
          "-Path",
          "%1"
        ]
      },
      "nsis": {
        "installMode": "perMachine",
        "languages": ["Russian", "English"],
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp",
        "installerHooks": "installer/hooks.nsh"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["infinityconnect"]
      }
    },
    "updater": {
      "endpoints": [
        "https://infinityconnect.ru/v1/client-updates/windows/{{arch}}/latest?current={{current_version}}",
        "https://github.com/InfinityLabs-LTD/InfinityConnect-Windows/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhDNTVENkJCODU2MTAyOTQKUldTVUFtR0Z1OVpWakJiempKUzNROXlabTZTV043L0tObzdJbU0vUVBxaXhJdG1zKzRibENJbVQK"
    }
  }
}
